{
  "name": "deepbench",
  "version": "0.1.0",
  "description": "Deep tools for any AI agent. Read, write, bash, glob, grep.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    },
    "./server": {
      "types": "./dist/server/ws-server.d.ts",
      "import": "./dist/server/ws-server.js"
    },
    "./spawn": {
      "types": "./dist/client/spawn.d.ts",
      "import": "./dist/client/spawn.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "mcp": "tsx src/mcp/server.ts",
    "server": "tsx src/server/ws-server.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "tools",
    "workspace",
    "bash"
  ],
  "author": "Vikas Mishra",
  "license": "MIT",
  "dependencies": {
    "just-bash": "^2.14.0",
    "zod": "3.25.76",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependencies": {
    "ai": ">=4"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@archildata/client": "^0.8.7",
    "@archildata/just-bash": "^0.8.7",
    "ws": "^8.20.0",
    "microsandbox": "^0.3.12"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "1",
    "@types/node": "^25.6.0",
    "ai": "4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "@types/ws": "^8.18.1"
  },
  "bin": {
    "deepbench-mcp": "./dist/mcp/server.js",
    "deepbench-server": "./dist/server/ws-server.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "microsandbox",
      "esbuild"
    ]
  }
}
